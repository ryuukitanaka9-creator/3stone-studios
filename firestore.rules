rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /news/{doc} {
      allow read: if true;
      allow write: if true;
    }

    match /scripts/{doc} {
      allow read: if true;
      allow write: if true;
    }

    match /achievements/{doc} {
      allow read: if true;
      allow write: if true;
    }

    match /config/{doc} {
      allow read: if true;
      allow write: if true;
    }

    match /heroSlides/{doc} {
      allow read: if true;
      allow write: if true;
    }

    // 上記以外は全拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
